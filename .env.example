# =============================================================================
# Sentinel Gateway - Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon Postgres)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# Generate a secure 32+ char secret: openssl rand -base64 32
BETTER_AUTH_SECRET="your-32-char-min-secret-here"

# Base URL for Better Auth (required for production)
# Local: http://localhost:3000
# Vercel Preview: https://your-preview.vercel.app
# Vercel Prod: https://your-production.vercel.app
BETTER_AUTH_URL="http://localhost:3000"

# Public version for client-side (NEXT_PUBLIC_ prefix exposes to browser)
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Vercel Environment Variables (auto-populated on Vercel)
# -----------------------------------------------------------------------------
# VERCEL_URL - Preview deployment URL (e.g., sentinalgateway-xxx.vercel.app)
# VERCEL_PROJECT_PRODUCTION_URL - Production URL (e.g., sentinalgateway.vercel.app)
# V0_RUNTIME_URL - v0 preview iframe URL (auto-set in v0 sandbox)

# -----------------------------------------------------------------------------
# Optional: Analytics & Monitoring
# -----------------------------------------------------------------------------
# VERCEL_ANALYTICS_ID="your-analytics-id"

# -----------------------------------------------------------------------------
# Optional: Rate Limiting (if adding Redis-based rate limiting)
# -----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-token"